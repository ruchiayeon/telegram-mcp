# ══════════════════════════════════════════════
#  텔레그램 채널 모니터 — 환경변수 템플릿
#  이 파일을 복사하여 .env 로 저장한 뒤 값을 채우세요.
#  cp .env.example .env
# ══════════════════════════════════════════════

# ── Telegram Bot API 토큰 ────────────────────────
# @BotFather 에서 발급
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ── Telegram User API 인증 ──────────────────────
# https://my.telegram.org/apps 에서 발급
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=abcdef1234567890abcdef1234567890

# 로그인에 사용할 전화번호 (국제번호 포함, 예: +821012345678)
TELEGRAM_PHONE=+821012345678

# ── 세션 파일명 ────────────────────────────────
# {SESSION_NAME}.session 파일로 저장됨
SESSION_NAME=telegram_session
